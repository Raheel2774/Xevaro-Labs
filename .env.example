# ─── Cloudflare D1 (contact form database) ───────────────────────────────────
# Create these in the Cloudflare dashboard (see DEPLOY.md).
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id
CF_D1_API_TOKEN=your_d1_api_token

# Without these, the contact form still works but submissions are NOT saved
# (the API logs a warning and returns success). Set them in production.
