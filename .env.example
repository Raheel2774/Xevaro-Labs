# ─── Cloudflare D1 (contact form database) ───────────────────────────────────
# Create these in the Cloudflare dashboard (see DEPLOY.md).
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_D1_DATABASE_ID=your_d1_database_id
CF_D1_API_TOKEN=your_d1_api_token

# Without these, the contact form still works but submissions are NOT saved
# (the API logs a warning and returns success). Set them in production.

# ─── Admin portal (/admin — view contact submissions) ────────────────────────
# Password to log into /admin. Choose a strong one.
ADMIN_PASSWORD=your_strong_admin_password
# Optional: separate secret for signing the session cookie (recommended).
ADMIN_SESSION_SECRET=any_long_random_string

# ─── Outbound engine ─────────────────────────────────────────────────────────
# Stage 1 — Google Places API (New). Has a free monthly tier; modest cost above.
# console.cloud.google.com → enable "Places API (New)" → create an API key.
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# RECOMMENDED source — Apify does Stage 1 + 1b in one run (find no-website
# businesses AND scrape emails), ~$0.009/lead. Replaces the Google + Outscraper
# pair below. console.apify.com → Settings → Integrations → API token.
APIFY_TOKEN=apify_api_xxx

# Stage 1b — Outscraper (alternative email enrichment, ~$0.01/lead). Optional
# if you use APIFY_TOKEN above. app.outscraper.com → Profile → API key.
OUTSCRAPER_API_KEY=your_outscraper_api_key

# Stage 2 — where demo sites are served (your Cloudflare Worker / custom domain)
DEMO_PUBLIC_BASE=https://demos.xevaro.app
DEMO_CLAIM_URL=https://xevarolabs.com/claim

# Stage 4 — sender identity
SENDER_NAME=Xevaro

# Stage 4 (SMS, the no-website funnel's delivery channel).
# The sender auto-picks Telnyx if TELNYX_API_KEY is set, else Twilio.
# NOTE: US carriers require registration (10DLC or toll-free verification) on
# EITHER provider for cold business SMS — switching providers doesn't skip it.

# Telnyx (preferred). console.telnyx.com → API Keys; create a Messaging Profile.
TELNYX_API_KEY=KEYxxxxxxxx
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=+17205550101

# Twilio (fallback).
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
TWILIO_FROM_NUMBERS=+17205550101,+17205550102

SMS_WINDOW=9-19

# Stage 4 (email, alt "outdated-website" funnel) — SMTP inboxes live in
# outbound/send/inboxes.json (no-website leads have no email, so unused here).

# ─── Social engine (inbound: content → engagement → leads) ───────────────────
# Generates + auto-publishes posts, harvests engagers, enriches them, and builds
# a human-approved outreach queue. Full runbook in social/README.md.

# AI generation (content calendar, posts, reply + DM drafts).
# console.anthropic.com → API Keys.
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional: override the model (default claude-opus-4-8). Use a cheaper model
# like claude-sonnet-4-6 for high-volume content.
CLAUDE_MODEL=claude-opus-4-8

# Publishing — self-hosted Postiz (one API for LinkedIn / IG / Facebook).
# Self-host: docs.postiz.com. Create an API key under Settings → Public API.
POSTIZ_URL=https://your-postiz-host
POSTIZ_API_KEY=your_postiz_public_api_key
# Channel ids — run: node social/publish/postiz-adapter.mjs --list
POSTIZ_LINKEDIN_ID=
POSTIZ_INSTAGRAM_ID=
POSTIZ_FACEBOOK_ID=

# Enrichment — turn a LinkedIn engager into a work email/title via Apollo.
# Apollo → Settings → API (consumes credits).
APOLLO_API_KEY=your_apollo_api_key
